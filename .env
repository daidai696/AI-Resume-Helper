# ===== App =====
APP_NAME=AI简历优化助手

# ===== Auth =====
# AUTH_ENABLED=false 时使用指纹登录(零配置),设为true需要配置Google OAuth
AUTH_ENABLED=false
AUTH_SECRET=dev-secret-key-change-in-production

# Google OAuth (可选,AUTH_ENABLED=true时需要)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Database =====
DB_TYPE=sqlite
SQLITE_PATH=./data/jade.db

# PostgreSQL (可选,生产环境使用)
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/jadeai

# ===== i18n =====
DEFAULT_LOCALE=zh
